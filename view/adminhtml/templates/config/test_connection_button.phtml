<div id="awx-test-connection-container" style="display: none;">
    <button type="button" id="airwallex_test_connection" class="action-default scalable">
        <span>Test Connection</span>
    </button>
    <div id="awx-test-connection-message" style="margin-top: 10px; display: none;"></div>
</div>

<script>
    require(['jquery'], function (jQuery) {
        let envSelector = '[name="groups[airwallex_payments][groups][basic][fields][mode][value]"]';

        let bindTestConnectionEvent = function() {
            jQuery('#airwallex_test_connection').on('click', function() {
                let env = document.querySelector(envSelector).value;
                let clientIdField = jQuery("input[name='groups[airwallex_payments][groups][basic][fields][" + env + "_client_id][value]']");
                let apiKeyField = jQuery("input[name='groups[airwallex_payments][groups][basic][fields][" + env + "_api_key][value]']");

                let clientId = jQuery.trim(clientIdField.val());
                let apiKey = jQuery.trim(apiKeyField.val());

                let messageEl = jQuery('#awx-test-connection-message');

                if (!clientId || !apiKey) {
                    messageEl.css('color', '#dc3232').text('Please enter Client ID and API Key first.').show();
                    return;
                }

                let button = jQuery(this);
                button.prop('disabled', true);
                button.find('span').text('Testing...');
                messageEl.hide();

                jQuery.ajax({
                    url: '<?= $block->escapeJs($block->getAjaxUrl()) ?>',
                    type: 'POST',
                    data: {
                        env: env,
                        client_id: clientId,
                        api_key: apiKey,
                        form_key: FORM_KEY
                    },
                    dataType: 'json',
                    success: function(response) {
                        button.prop('disabled', false);
                        button.find('span').text('Test Connection');

                        if (response.success) {
                            messageEl.css('color', '#006400').text(response.message).show();
                        } else {
                            messageEl.css('color', '#dc3232').text(response.message).show();
                        }
                    },
                    error: function() {
                        button.prop('disabled', false);
                        button.find('span').text('Test Connection');
                        messageEl.css('color', '#dc3232').text('Connection test failed. Please try again.').show();
                    }
                });
            });
        };

        let bindCredentialChangeEvents = function() {
            jQuery(document).on('input change', '[name^="groups[airwallex_payments][groups][basic][fields][demo_client_id]"], [name^="groups[airwallex_payments][groups][basic][fields][demo_api_key]"], [name^="groups[airwallex_payments][groups][basic][fields][prod_client_id]"], [name^="groups[airwallex_payments][groups][basic][fields][prod_api_key]"]', function() {
                jQuery('#awx-test-connection-message').hide();
            });

            jQuery(envSelector).on('change', function() {
                jQuery('#awx-test-connection-message').hide();
            });
        };

        jQuery(document).ready(function() {
            bindTestConnectionEvent();
            bindCredentialChangeEvents();
        });
    });
</script>

<style>
    #awx-test-connection-message {
        margin-top: 10px;
        font-size: 13px;
        line-height: 1.5;
    }

    #airwallex_test_connection {
        margin-top: 10px;
    }
</style>
