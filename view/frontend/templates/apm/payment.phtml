$paymentConfig = $block->getPaymentConfig();
$orderDetails = $block->getOrderDetails();

if (!$paymentConfig) {
    echo '<div class="message error">' .
        $escaper->escapeHtml(__('Unable to load payment information. Please try again.')) .
        '</div>';
    return;
}
?>

<div class="airwallex-apm-page">
    <div class="airwallex-apm-container">
        <div class="airwallex-apm-left">
            <?php if ($orderDetails): ?>
            <div class="airwallex-order-summary">
                <h3><?= $escaper->escapeHtml(__('Order Summary')) ?></h3>

                <?php if (!empty($orderDetails['items'])): ?>
                <div class="airwallex-order-items">
                    <table class="data table">
                        <thead>
                            <tr>
                                <th><?= $escaper->escapeHtml(__('Product')) ?></th>
                                <th class="col qty"><?= $escaper->escapeHtml(__('Qty')) ?></th>
                                <th class="col price"><?= $escaper->escapeHtml(__('Price')) ?></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($orderDetails['items'] as $item): ?>
                            <tr>
                                <td><?= $escaper->escapeHtml($item['name']) ?></td>
                                <td class="col qty"><?= (int)$item['qty'] ?></td>
                                <td class="col price">
                                    <?= $escaper->escapeHtml($block->formatPrice($item['row_total'])) ?>
                                </td>
                            </tr>
                            <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>
                <?php endif; ?>

                <div class="airwallex-order-info">
                    <div class="airwallex-order-subtotal">
                        <span><?= $escaper->escapeHtml(__('Subtotal')) ?></span>
                        <span><?= $escaper->escapeHtml($block->formatPrice($orderDetails['subtotal'])) ?></span>
                    </div>

                    <?php if (!empty($orderDetails['shipping_amount']) && $orderDetails['shipping_amount'] > 0): ?>
                    <div class="airwallex-order-shipping">
                        <span>
                            <?= $escaper->escapeHtml(__('Shipping')) ?>
                            <?php if (!empty($orderDetails['shipping_description'])): ?>
                                <span class="airwallex-shipping-method">
                                    (<?= $escaper->escapeHtml($orderDetails['shipping_description']) ?>)
                                </span>
                            <?php endif; ?>
                        </span>
                        <span><?= $escaper->escapeHtml($block->formatPrice($orderDetails['shipping_amount'])) ?></span>
                    </div>
                    <?php endif; ?>

                    <?php if (!empty($orderDetails['tax_amount']) && $orderDetails['tax_amount'] > 0): ?>
                    <div class="airwallex-order-tax">
                        <span><?= $escaper->escapeHtml(__('Tax')) ?></span>
                        <span><?= $escaper->escapeHtml($block->formatPrice($orderDetails['tax_amount'])) ?></span>
                    </div>
                    <?php endif; ?>

                    <?php if (!empty($orderDetails['discount_amount']) && $orderDetails['discount_amount'] < 0): ?>
                    <div class="airwallex-order-discount">
                        <span><?= $escaper->escapeHtml(__('Discount')) ?></span>
                        <span><?= $escaper->escapeHtml($block->formatPrice($orderDetails['discount_amount'])) ?></span>
                    </div>
                    <?php endif; ?>

                    <div class="airwallex-order-total">
                        <strong><?= $escaper->escapeHtml(__('Grand Total')) ?></strong>
                        <span class="airwallex-price">
                            <?= $escaper->escapeHtml($orderDetails['currency_code']) ?>
                            <?= $escaper->escapeHtml($block->formatPrice($orderDetails['grand_total'])) ?>
                        </span>
                    </div>
                </div>

                <div id="airwallex-currency-conversion" class="airwallex-currency-conversion" style="display: none;">
                    <div class="airwallex-conversion-rate" id="airwallex-conversion-rate"></div>
                    <div class="airwallex-conversion-total">
                        <span class="airwallex-label"><?= $escaper->escapeHtml(__('You Pay')) ?></span>
                        <span class="airwallex-conversion-price" id="airwallex-conversion-amount"></span>
                    </div>
                </div>
            </div>
            <?php endif; ?>
        </div>

        <div class="airwallex-apm-right">
            <div id="airwallex-error-message" class="message message-error error" style="display: none;"></div>

            <div id="airwallex-apm-container">
                <div id="airwallex-loading-overlay">
                    <div class="airwallex-loading-content">
                        <div class="airwallex-spinner-border" role="status"></div>
                        <p class="airwallex-loading-text">
                            <?= $escaper->escapeHtml(__('Payment processing...')) ?>
                        </p>
                    </div>
                </div>
                <div id="airwallex-apm-element"></div>
            </div>
        </div>
    </div>
</div>

