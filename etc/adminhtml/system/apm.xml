<?xml version="1.0"?>

<include xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_include.xsd">
    <group id="apm" translate="label" type="text" sortOrder="22" showInDefault="1" showInWebsite="1" showInStore="1">
        <label>All Payment Methods (Embedded Element)</label>
        <field id="active" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1">
            <label>Enable</label>
            <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
            <config_path>payment/airwallex_payments_apm/active</config_path>
        </field>
        <field id="title" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Title</label>
            <comment><![CDATA[This is the payment method title used at the checkout page.]]></comment>
            <config_path>payment/airwallex_payments_apm/title</config_path>
        </field>
        <field id="enabled_methods" translate="label comment" type="text" sortOrder="45" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Enabled Payment Methods</label>
            <frontend_model>Airwallex\Payments\Block\Adminhtml\System\Config\EnabledPaymentMethods</frontend_model>
            <config_path>payment/airwallex_payments_apm/enabled_methods</config_path>
            <can_be_empty>1</can_be_empty>
        </field>
        <field id="selected_payment_method_logos" translate="label comment" type="text" sortOrder="46" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Display Payment Method Logos</label>
            <frontend_model>Airwallex\Payments\Block\Adminhtml\System\Config\PaymentMethodLogos</frontend_model>
            <config_path>payment/airwallex_payments_apm/selected_payment_method_logos</config_path>
            <can_be_empty>1</can_be_empty>
        </field>
        <field id="airwallex_payment_action" translate="label comment" type="select" sortOrder="46" showInDefault="1" showInWebsite="0" showInStore="0">
            <label>Capture Preferences</label>
            <comment><![CDATA[Payment methods that don't support authorization/hold will be automatically captured.]]></comment>
            <source_model>Airwallex\Payments\Model\Config\Source\PaymentAction</source_model>
            <config_path>payment/airwallex_payments_apm/airwallex_payment_action</config_path>
        </field>
        <field id="allowspecific" translate="label" type="allowspecific" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Payment From Applicable Countries</label>
            <source_model>Magento\Payment\Model\Config\Source\Allspecificcountries</source_model>
            <config_path>payment/airwallex_payments_apm/allowspecific</config_path>
        </field>
        <field id="specificcountry" translate="label comment" type="multiselect" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Display Payment Method For</label>
            <comment><![CDATA[Select the countries and currencies for which Airwallex is available at the checkout.]]></comment>
            <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
            <config_path>payment/airwallex_payments_apm/specificcountry</config_path>
            <depends>
                <field id="allowspecific">1</field>
            </depends>
        </field>
        <field id="sort_order" translate="label" type="text" sortOrder="210" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Sort Order</label>
            <comment>Adjust this to move the payment method above or below other payment methods.</comment>
            <frontend_class>validate-number</frontend_class>
            <config_path>payment/airwallex_payments_apm/sort_order</config_path>
        </field>
    </group>
</include>
